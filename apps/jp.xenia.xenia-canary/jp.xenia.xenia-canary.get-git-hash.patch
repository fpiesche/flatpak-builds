diff --git a/CMakeLists.txt b/CMakeLists.txt
index 193f6d8..386ea4c 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -179,7 +179,7 @@ else()
   add_compile_options(${GTK3_CFLAGS_OTHER})
 
   # Global Linux libraries
-  link_libraries(stdc++fs dl lz4 pthread rt)
+  link_libraries(dl lz4 pthread rt)
 
   # Link groups for executables (resolves circular deps)
   set(CMAKE_EXE_LINKER_FLAGS "${CMAKE_EXE_LINKER_FLAGS} -Wl,--start-group")
@@ -229,3 +229,24 @@ add_subdirectory(src/xenia)
 
 # Set default startup project for Visual Studio
 set_property(DIRECTORY ${CMAKE_CURRENT_SOURCE_DIR} PROPERTY VS_STARTUP_PROJECT xenia-app)
+
+execute_process(
+    COMMAND git log -1 --format=%H
+    WORKING_DIRECTORY ${CMAKE_CURRENT_LIST_DIR}
+    OUTPUT_VARIABLE GIT_HASH
+    OUTPUT_STRIP_TRAILING_WHITESPACE
+    )
+execute_process(
+    COMMAND git log -1 --format=%h
+    WORKING_DIRECTORY ${CMAKE_CURRENT_LIST_DIR}
+    OUTPUT_VARIABLE GIT_HASH_SHORT
+    OUTPUT_STRIP_TRAILING_WHITESPACE
+    )
+
+configure_file(version.h.in ${CMAKE_CURRENT_SOURCE_DIR}/src/build/version.h @ONLY)
+message(STATUS "Compiling shaders...")
+execute_process(COMMAND python xenia-build.py buildshaders
+                COMMAND_ERROR_IS_FATAL ANY
+                WORKING_DIRECTORY ${CMAKE_CURRENT_SOURCE_DIR})
+
+install(TARGETS "xenia-app" COMPONENT Executable)
